\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{raidUtils}

% --- Dépendances ---
\RequirePackage{graphicx, wrapfig, subcaption, setspace, booktabs}
\RequirePackage{fourier}
\RequirePackage{sectsty}
\RequirePackage{xcolor}


% --- Configuration des lignes et style ---
\newcommand{\HRule}[1]{\rule{\linewidth}{#1}}
\onehalfspacing
\sectionfont{\scshape}

% --- Réduit l'espace en haut des chapitres (numérotés et non numérotés) ---
\makeatletter
\renewcommand{\@makeschapterhead}[1]{%
  \vspace*{-30pt}%
  {\parindent \z@ \raggedright
    \normalfont
    \interlinepenalty\@M
    \Huge \bfseries #1\par\nobreak
    \vskip 20\p@
  }}
\renewcommand{\@makechapterhead}[1]{%
  \vspace*{-30pt}%
  {\parindent \z@ \raggedright
    \normalfont
    \interlinepenalty\@M
    \Huge \bfseries \thechapter\quad #1\par\nobreak
    \vskip 20\p@
  }}

% --- Logique des variables internes ---
\newcommand{\supervised}[1]{\gdef\@supervised{#1}}
\def\@supervised{Aucun encadrant spécifié}

% --- La Fonction de Page de Garde ---
\newcommand{\makeCustomTitle} {
\begin{titlepage}
    \centering
    \vspace*{1cm}
    \textsc{\normalsize Rapport de Projet de Master}\\[2.0cm]
    
    \HRule{0.5pt} \\ [0.4cm]
    \LARGE \textbf{\@title} \\ 
    \HRule{2pt} \\ [1.5cm]
    
    \normalsize \@date \\[2cm]

    \begin{minipage}{\textwidth}
        \centering
        \large \@author 
    \end{minipage} \\[1.5cm]

    \textit{Supervisé par :}\\
    \@supervised 

    \vfill
\end{titlepage}
}

\makeatother

\newenvironment{customabstract}{
    \begin{center}
      {\LARGE \textbf{Résumé}\par}
      \vspace{1em}
    \end{center}%
    \quotation
}{
    \endquotation
    \newpage
}

\newcommand{\citefull}[1] {\textit{\citetitle{#1}}~\cite{#1}}